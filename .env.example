# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres (Prisma) — Project Settings → Database
# Local dev / direct connection:
DATABASE_URL=
# Vercel's Supabase integration provisions these automatically in production
# (pooled Supavisor endpoint) — leave unset locally:
# POSTGRES_PRISMA_URL=
# POSTGRES_URL=

# Market data — brapi.dev (https://brapi.dev/dashboard)
# Optional: without it, detail sync (dividends/history/fundamentals) only
# works for brapi's 4 free sandbox tickers (PETR4, VALE3, MGLU3, ITUB4).
# The company-directory sync (full B3 universe, basic quotes) never needs it.
BRAPI_API_TOKEN=
# MARKET_DATA_PROVIDER=brapi

# Provider priority (lower tries first) — change these to reprioritize
# without a code change. Defaults: BRAPI=1 (official source), Yahoo=2
# (failover only, used only when BRAPI errors/times out/rate-limits).
# MARKET_DATA_PRIORITY_BRAPI=1
# MARKET_DATA_PRIORITY_YAHOO=2

# Vercel Cron — auto-provisioned by Vercel when the project has cron jobs;
# set manually for local testing of /api/cron/* routes.
CRON_SECRET=
