// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────

/// Mirrors auth.users.id (Supabase-managed). Prisma cannot reach into the
/// `auth` schema, so this is a logical 1:1 — provisioned by an upsert in
/// requireUser() on the user's first authenticated request (no Postgres
/// trigger here, unlike the sibling SSmoney project).
model Profile {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  avatarUrl String?
  currency  String   @default("BRL")
  locale    String   @default("pt-BR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites          Favorite[]
  portfolioEntries   PortfolioPosition[]
  transactions       Transaction[]
  preferences        UserPreferences?
  searchLogs         SearchLog[]
  targetAllocations  TargetAllocation[]
  aiContents         AiContent[]
  radarNotifications RadarNotification[]
  savedMarketFilters SavedMarketFilter[]

  @@map("profiles")
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum LayoutPreference {
  COMFORTABLE
  COMPACT
}

enum ExperienceMode {
  BEGINNER
  ADVANCED
}

/// Genuinely new preferences only — currency/locale already live on
/// Profile (currency, locale) and are reused as-is, not duplicated here.
model UserPreferences {
  id             String           @id @default(uuid())
  profileId      String           @unique
  profile        Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  theme          ThemePreference  @default(SYSTEM)
  layout         LayoutPreference @default(COMFORTABLE)
  experienceMode ExperienceMode   @default(BEGINNER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("user_preferences")
}

// ─────────────────────────────────────────────────────────
// Market catalog
// ─────────────────────────────────────────────────────────

enum AssetClass {
  STOCK
  FII
  ETF
  /// BDR (Brazilian Depositary Receipt) — synced from brapi's directory
  /// like STOCK/FII/ETF, just a different `type|subType` bucket.
  BDR
  /// No market-data provider wired up yet — Company rows are created
  /// manually via the portfolio's "Adicionar Investimento" flow, and
  /// trades always require the manual price override (no historical
  /// lookup is possible without a real data source).
  CRYPTO
  /// Renda Fixa (Tesouro Selic/Prefixado/IPCA+, CDB, LCI, LCA, debêntures,
  /// CRI/CRA, fundos DI/RF, ...). Same manual-entry-only status as CRYPTO
  /// for now — the category exists and positions can be tracked, but sub-
  /// instrument-type modeling and real pricing feeds are a later phase.
  FIXED_INCOME
  /// Catch-all for anything not covered above (fundos de investimento,
  /// previdência, REITs, commodities, ouro, prata, ...) — same manual-
  /// entry-only status.
  OTHER
}

/// Where a Company's current price (and, by extension, whether a trade
/// against it needs a manual price at entry time) comes from. Replaces the
/// old isManualEntry boolean — an enum scales to new origins without ever
/// needing another boolean bolted on next to it.
enum PriceSource {
  /// Synced automatically by a market-data provider (BRAPI today, whichever
  /// ProviderManager picks tomorrow). The default for every Company row a
  /// directory/detail sync creates or touches.
  AUTO
  /// Entered by hand via the portfolio's "Adicionar Investimento" flow
  /// (findOrCreateManualCompany) — no provider covers this ticker, so every
  /// trade against it requires a manual price at entry time. A real
  /// directory sync flips this back to AUTO the moment it upserts a
  /// matching ticker for real (see MarketDataService.refreshCompanyDirectory).
  MANUAL
  /// Not implemented yet — reserved for a future Open Finance integration,
  /// where a connected institution supplies the position/price directly
  /// (e.g. a CDB or LCI held at a bank, synced via the bank's Open Finance
  /// API rather than typed in). Like AUTO, trades against an OPEN_FINANCE
  /// company should never require a manual price once that integration
  /// exists — the price arrives with the sync, not from the user.
  OPEN_FINANCE
  /// Not implemented yet — reserved for a future brokerage-note/CSV
  /// importer, where the operation (and its price) is read from an imported
  /// document rather than typed in one field at a time. Like AUTO/
  /// OPEN_FINANCE, doesn't need a manual price prompt — the import brings it.
  IMPORTED
}

/// Canonical registry for every listed asset (ação, FII ou ETF). Holds the
/// fields shared across all three classes; class-specific fundamentals live
/// in the 1:1 Stock/Fii/Etf extension tied to `assetClass`.
model Company {
  id                String     @id @default(uuid())
  ticker            String     @unique
  name              String
  logoUrl           String?
  description       String?
  sector            String?
  segment           String?
  assetClass        AssetClass
  currency          String     @default("BRL")
  priceCents        Int        @default(0)
  priceChangePct    Decimal    @default(0) @db.Decimal(8, 4)
  marketCapCents    BigInt?
  /// Day/52-week range and volume — available for every ticker via BRAPI's
  /// basic quote payload (no premium modules needed), just not mapped yet.
  dayHighCents          Int?
  dayLowCents           Int?
  fiftyTwoWeekHighCents Int?
  fiftyTwoWeekLowCents  Int?
  volume                BigInt?
  listedAt          DateTime?
  /// Last time dividends/history/fundamentals were pulled from the provider
  /// (the token-gated "detail" call) — distinct from `updatedAt`, which also
  /// changes on every cheap directory-sync price refresh. Null = never synced.
  detailsSyncedAt   DateTime?
  /// Origin tracking for whatever is currently in priceCents/priceChangePct/
  /// marketCapCents — which provider supplied it, when, how long the call
  /// took, how many providers had to be tried before one produced a value
  /// that passed validation, and the outcome. Written by MarketDataService
  /// on every successful (or rejected-but-handled) quote update.
  lastQuoteProvider   String?
  lastQuoteAt         DateTime?
  lastQuoteLatencyMs  Int?
  /// Number of different providers attempted to land this value — 1 when
  /// BRAPI answered validly on the first try, 2+ when a fallback/re-check
  /// was needed. Not HTTP retry count (that's internal to fetchWithRetry).
  lastQuoteAttempts   Int?
  /// "OK" | "REJECTED_KEPT_LAST_VALID" — see QuoteValidationAlert for why,
  /// when the latter.
  lastQuoteStatus     String?
  /// See the PriceSource enum doc comments. Drives whether trades against
  /// this company require a manual price at entry time (only MANUAL does).
  priceSource       PriceSource @default(AUTO)
  /// True when this instrument trades on a public exchange (B3, a crypto
  /// exchange, ...) at all — independent of priceSource/whether *we* sync
  /// it. E.g. Bitcoin is exchange-traded (true) even when added manually
  /// because no provider is wired up yet; a CDB or a Fundo Multimercado is
  /// never exchange-traded (false) regardless of how its price is sourced.
  /// Not surfaced in any UI yet — purely architectural prep for filtering/
  /// grouping once more categories (Renda Fixa sub-types, Outros) exist.
  listedOnExchange  Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  stock                  Stock?
  fii                    Fii?
  etf                    Etf?
  priceHistory           PriceHistoryPoint[]
  dividendHistory        DividendPayment[]
  favorites              Favorite[]
  portfolioEntries       PortfolioPosition[]
  transactions           Transaction[]
  quoteValidationAlerts  QuoteValidationAlert[]
  aiContent              AiContent[]
  searchLogs             SearchLog[]
  radarEvents            RadarEvent[]
  radarNotifications     RadarNotification[]

  @@index([assetClass])
  @@index([sector])
  @@map("companies")
}

/// Written whenever a fetched quote fails validateQuote() and no provider
/// among the ones tried produced a plausible alternative — the last known
/// good value in Company is deliberately left untouched, and this row is
/// the audit trail for why nothing changed. Not a call-by-call API log
/// (that's ProviderHealth's job at the aggregate level); this only exists
/// when there was something to flag.
model QuoteValidationAlert {
  id                 String   @id @default(uuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider           String
  reasons            String[]
  rejectedPriceCents Int?
  previousPriceCents Int?
  createdAt          DateTime @default(now())

  @@index([companyId, createdAt])
  @@map("quote_validation_alerts")
}

/// Stock-specific fundamentals (indicadores fundamentalistas). The block
/// added below (psr..sharesOutstanding) is only ever populated by BRAPI's
/// premium `defaultKeyStatistics`/`financialData` modules — on the current
/// plan tier that's just the 4 sandbox tickers (PETR4/VALE3/ITUB4/MGLU3),
/// so these stay null for the rest of the universe until a plan upgrade.
/// Deliberately NOT modeled here: Tag Along, Fluxo de Caixa — no real data
/// source exists for either at any BRAPI/Yahoo plan tier; see
/// src/features/company/indicators.ts's "never-available" entries instead
/// of adding a column that could only ever be guessed at.
model Stock {
  id                String   @id @default(uuid())
  companyId         String   @unique
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  priceToEarnings   Decimal? @db.Decimal(10, 2)
  priceToBook       Decimal? @db.Decimal(10, 2)
  roe               Decimal? @db.Decimal(8, 4)
  roic              Decimal? @db.Decimal(8, 4)
  dividendYield     Decimal? @db.Decimal(8, 4)
  netMargin         Decimal? @db.Decimal(8, 4)
  netDebtCents      BigInt?
  equityCents       BigInt?
  psr                Decimal? @db.Decimal(8, 4)
  evToEbit           Decimal? @db.Decimal(8, 4)
  evToEbitda         Decimal? @db.Decimal(8, 4)
  roa                Decimal? @db.Decimal(8, 4)
  grossMargin        Decimal? @db.Decimal(8, 4)
  ebitdaMargin       Decimal? @db.Decimal(8, 4)
  payout             Decimal? @db.Decimal(8, 4)
  currentLiquidity   Decimal? @db.Decimal(8, 4)
  revenueCents       BigInt?
  netIncomeCents     BigInt?
  ebitdaCents        BigInt?
  grossDebtCents     BigInt?
  netDebtToEbitda    Decimal? @db.Decimal(8, 4)
  revenueCagr3y      Decimal? @db.Decimal(8, 4)
  netIncomeCagr3y    Decimal? @db.Decimal(8, 4)
  freeFloatPct       Decimal? @db.Decimal(8, 4)
  beta               Decimal? @db.Decimal(8, 4)
  bookValuePerShareCents Int?
  sharesOutstanding  BigInt?
  updatedAt         DateTime @updatedAt

  @@map("stocks")
}

/// FII-specific fundamentals.
model Fii {
  id             String   @id @default(uuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  priceToBook    Decimal? @db.Decimal(10, 2)
  dividendYield  Decimal? @db.Decimal(8, 4)
  netWorthCents  BigInt?
  managementFee  Decimal? @db.Decimal(8, 4)
  vacancyRate    Decimal? @db.Decimal(8, 4)
  propertyCount  Int?
  quotaCount     BigInt?
  administrator  String?
  updatedAt      DateTime @updatedAt

  @@map("fiis")
}

/// ETF-specific fundamentals.
model Etf {
  id             String   @id @default(uuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  benchmarkIndex String?
  expenseRatio   Decimal? @db.Decimal(8, 4)
  navCents       BigInt?
  dividendYield  Decimal? @db.Decimal(8, 4)
  updatedAt      DateTime @updatedAt

  @@map("etfs")
}

/// Daily/close price series backing the "Histórico de Preço" chart.
model PriceHistoryPoint {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date       DateTime
  closeCents Int
  volume     BigInt?
  createdAt  DateTime @default(now())

  @@unique([companyId, date])
  @@index([companyId, date])
  @@map("price_history_points")
}

enum DividendType {
  DIVIDEND
  JCP
  RENDIMENTO
}

/// Per-share dividend/JCP/rendimento events backing "Histórico de Dividendos".
model DividendPayment {
  id             String       @id @default(uuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type           DividendType @default(DIVIDEND)
  amountPerShare Decimal      @db.Decimal(12, 6)
  exDate         DateTime
  paymentDate    DateTime?
  createdAt      DateTime     @default(now())

  @@unique([companyId, exDate, type])
  @@index([companyId, exDate])
  @@map("dividend_payments")
}

// ─────────────────────────────────────────────────────────
// Market data sync
// ─────────────────────────────────────────────────────────

enum SyncJobType {
  COMPANY_DIRECTORY
  COMPANY_DETAILS
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

/// One row per sync run — the audit trail for "registrar logs de
/// sincronização". Written by runSyncJob() in src/features/market-sync/,
/// never by UI code.
model SyncLog {
  id             String      @id @default(uuid())
  type           SyncJobType
  status         SyncStatus  @default(RUNNING)
  itemsProcessed Int         @default(0)
  itemsFailed    Int         @default(0)
  errorMessage   String?
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?

  @@index([type, startedAt])
  @@map("sync_logs")
}

enum ProviderStatus {
  ONLINE
  DEGRADED
  OFFLINE
}

/// Rolling current-state snapshot per MarketDataProvider — what
/// ProviderManager reads to decide routing/failover and what a future
/// admin panel reads to show provider status. One row per provider name,
/// updated after every single provider call (success or failure). Not a
/// call-by-call log (that's ProviderLog, a later phase) — just "how is this
/// provider doing right now."
model ProviderHealth {
  id                 String         @id @default(uuid())
  providerName       String         @unique
  status             ProviderStatus @default(ONLINE)
  consecutiveFailures Int           @default(0)
  totalRequests      Int            @default(0)
  totalFailures      Int            @default(0)
  lastLatencyMs      Int?
  avgLatencyMs       Int?
  lastError          String?
  lastSuccessAt      DateTime?
  lastCheckedAt      DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("provider_health")
}

// ─────────────────────────────────────────────────────────
// AI-generated content (Resumo Inteligente, indicator explanations)
// ─────────────────────────────────────────────────────────

enum AiContentKind {
  SUMMARY
  INDICATOR_EXPLANATION
  /// Auto-generated "Resumo Executivo" on /comparar — see comparisonKey below.
  COMPARISON_SUMMARY
  /// "Analisar Comparação" button result on /comparar.
  COMPARISON_ANALYSIS
  /// "Radar do Dia"/"IA Financeira" on /radar — see profileId below, the
  /// only AiContentKind that is ever profile-scoped instead of company-scoped.
  RADAR_SUMMARY
}

enum AiQuestionType {
  WHAT_IS
  HOW_INTERPRET
  IS_HIGH
  COMPARE_SECTOR
  HOW_CALCULATE
}

/// Cache/persistence for every AI-generated string this app ever shows —
/// src/services/ai-content-service.ts is the only code allowed to write
/// here (mirrors MarketDataService's exclusivity over provider calls).
/// `companyId: null` rows are generic answers shared across every company
/// of the same `assetClass` (only WHAT_IS/HOW_CALCULATE ever do this — the
/// other question types reference a specific value/sector comparison and
/// always need their own row). `sourceHash` is a hash of exactly the inputs
/// the prompt used; a mismatch means the underlying data moved on and the
/// cached text should be regenerated rather than trusted as still accurate.
/// The `@@unique` below is documentation, not an enforced guarantee —
/// Postgres treats every NULL as distinct in a unique index, so it can't
/// actually prevent duplicate generic (companyId: null) rows;
/// ai-content-service.ts reads/writes via findFirst + create-or-update
/// rather than upsert-by-key for exactly this reason. A rare duplicate is a
/// harmless idle cache row, not a correctness issue.
model AiContent {
  id           String          @id @default(uuid())
  companyId    String?
  company      Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kind         AiContentKind
  /// Only set on the generic (companyId: null) rows — scopes them to a
  /// category so a FII's "o que é P/VP" answer never leaks into a stock's.
  assetClass   AssetClass?
  indicatorKey String?
  questionType AiQuestionType?
  content      String          @db.Text
  /// Model id that produced this text — provenance, not a behavior switch.
  model        String
  sourceHash   String
  generatedAt  DateTime        @default(now())
  /// TTL fallback (30 days) for content whose sourceHash never changes —
  /// sourceHash mismatch is the primary invalidation path, this just caps
  /// how stale a genuinely-unchanged answer is allowed to get.
  expiresAt    DateTime?
  /// Identifies a /comparar multi-company comparison (sorted, comma-joined
  /// ticker list, e.g. "BBAS3,PETR4") for COMPARISON_SUMMARY/
  /// COMPARISON_ANALYSIS rows — null for every single-company row.
  /// companyId can't represent a set of companies, hence this separate
  /// column rather than overloading companyId or assetClass.
  comparisonKey String?
  /// Set only for RADAR_SUMMARY rows — a portfolio-level AI summary has no
  /// company/comparison to key off, just the profile it was generated for.
  /// Null for every pre-existing row (company/comparison-scoped content).
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([companyId, kind, assetClass, indicatorKey, questionType, comparisonKey, profileId], map: "ai_content_unique_key")
  @@index([companyId, kind])
  @@map("ai_content")
}

// ─────────────────────────────────────────────────────────
// Favorites
// ─────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([profileId, companyId])
  @@map("favorites")
}

// ─────────────────────────────────────────────────────────
// Portfolio
// ─────────────────────────────────────────────────────────

/// Current aggregated holding per (profile, company) — the "Carteira" row.
/// Kept in sync transactionally whenever a Transaction is created/edited/
/// deleted, mirroring the write-time-aggregate pattern (not derived on read).
model PortfolioPosition {
  id                   String   @id @default(uuid())
  profileId            String
  profile              Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quantity             Decimal  @default(0) @db.Decimal(18, 8)
  averagePriceCents    Int      @default(0)
  totalInvestedCents   BigInt   @default(0)
  totalDividendsCents  BigInt   @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([profileId, companyId])
  @@map("portfolio_positions")
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  JCP
  /// Bonificação — free shares received, no cash outlay; spreads the
  /// existing cost basis over more shares (lowers average price).
  BONUS
  /// Desdobramento — quantity increases, average price decreases
  /// proportionally; total invested is unchanged.
  SPLIT
  /// Grupamento — quantity decreases, average price increases
  /// proportionally; total invested is unchanged.
  REVERSE_SPLIT
}

/// Immutable ledger of buy/sell/dividend/corporate-action events. Source of
/// truth that PortfolioPosition is aggregated from — never written to
/// directly, always through src/services/portfolio-service.ts, which
/// recomputes the whole position by replaying every transaction in
/// chronological order (see recomputePosition()).
model Transaction {
  id          String          @id @default(uuid())
  profileId   String
  profile     Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        TransactionType
  quantity    Decimal         @db.Decimal(18, 8)
  priceCents  Int
  totalCents  BigInt
  feesCents   Int             @default(0)
  /// Provider name that supplied the historical price ("brapi.dev",
  /// "yahoo-finance"), "cache" if it was already stored, or "manual" for
  /// an operator-entered override. Plain string, not an enum — a new
  /// provider shouldn't need a migration to be recorded here.
  priceSource String?
  /// True when the price came from the "Editar preço da operação" override
  /// rather than the automatic historical lookup.
  isManualPrice      Boolean  @default(false)
  /// Only set on SELL rows — realized gain/loss for this specific sale,
  /// computed against the running average price at the moment it occurred.
  /// Recomputed (not just set once) whenever an earlier transaction for
  /// the same position is edited or deleted, since that can change the
  /// average price this sale was measured against.
  realizedProfitCents BigInt?
  date        DateTime
  note        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([profileId, date])
  @@index([profileId, companyId])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────
// Search
// ─────────────────────────────────────────────────────────

enum SearchLogKind {
  /// A result was selected from the global search dropdown/autocomplete.
  SEARCH
  /// The /empresa/[ticker] page was viewed, via any entry point.
  VIEW
}

/// Real usage log — backs "mais pesquisados" (aggregate SEARCH count),
/// "últimos ativos vistos" (per-profile VIEW rows), and "últimas
/// pesquisas" (per-profile SEARCH rows). Replaces the hardcoded
/// POPULAR_TICKERS list that used to stand in for "popular" in
/// market/queries.ts. `profileId` is null for an anonymous visitor —
/// their own recent list lives in localStorage instead, but the
/// anonymous click itself still counts toward the global SEARCH
/// aggregate, so "mais pesquisados" reflects real site-wide activity,
/// not just logged-in users.
model SearchLog {
  id        String        @id @default(uuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profileId String?
  profile   Profile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind      SearchLogKind
  /// Raw text typed when this was a SEARCH selection — null for VIEW rows.
  /// Never used for ranking (companyId is); kept only for future query-
  /// quality analysis.
  query     String?
  createdAt DateTime      @default(now())

  @@index([companyId, kind, createdAt])
  @@index([profileId, kind, createdAt])
  @@map("search_logs")
}

// ─────────────────────────────────────────────────────────
// Rebalancing
// ─────────────────────────────────────────────────────────

/// A user-configured target allocation, one row per category they've set a
/// goal for — absence of a row for a category simply means "no target set
/// for this category," not a target of 0%. Read-only comparison logic
/// lives in src/features/portfolio/rebalancing.ts; this table never
/// affects PortfolioPosition/Transaction or portfolio-service.ts at all.
model TargetAllocation {
  id         String   @id @default(uuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  assetClass AssetClass
  targetPct  Decimal  @db.Decimal(5, 2)
  updatedAt  DateTime @updatedAt

  @@unique([profileId, assetClass])
  @@map("target_allocations")
}

// ─────────────────────────────────────────────────────────
// Radar
// ─────────────────────────────────────────────────────────

/// The event taxonomy shared by RadarEvent.type and RadarNotification.type —
/// one list, since a notification is just an event a user opted to be
/// pushed about. EARNINGS/ASSEMBLY/IPO/TREASURY/NEWS have no populating
/// sync yet (no earnings-calendar/news provider is wired up) — the enum
/// values exist so /radar's "Próximos Eventos"/"Radar de Resultados"/
/// "Notícias" sections and RadarEvent rows already have a real, stable
/// category to slot into the day a real provider is added, instead of a
/// schema change being required later.
enum RadarType {
  PRICE_MOVE
  BUY
  SELL
  DIVIDEND
  JCP
  BONUS
  SPLIT
  REVERSE_SPLIT
  EARNINGS
  ASSEMBLY
  IPO
  TREASURY
  NEWS
  INDICATOR_CHANGE
  ALERT
}

enum RadarPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Lifecycle for both RadarEvent (draft a sync job wrote vs. shown on the
/// page vs. superseded) and RadarNotification (queued vs. delivered vs.
/// dismissed by the user) — same three stages read differently depending
/// on which model it's attached to, documented on each field instead of
/// forking into two near-identical enums.
enum RadarStatus {
  PENDING
  PUBLISHED
  ARCHIVED
}

/// Prepared infrastructure for a future real event pipeline (a BRAPI
/// Premium earnings-calendar sync, a news-provider sync, a corporate-action
/// feed, etc.) — nothing writes to this table yet. Today's /radar page
/// computes its feed live from Transaction/Company/PortfolioPosition (the
/// same real, already-trustworthy tables every other Carteira feature
/// reads), never from here — reading an empty RadarEvent table would just
/// mean an empty feed, so the page doesn't depend on it existing yet. Once
/// a real sync populates rows here (e.g. nightly earnings-calendar pull),
/// src/features/radar/queries.ts's getRadarFeed can start merging them in
/// without any UI rewrite — every feed card already renders from the same
/// {type, title, description, occurredAt} shape this table stores.
model RadarEvent {
  id          String        @id @default(uuid())
  type        RadarType
  priority    RadarPriority @default(MEDIUM)
  status      RadarStatus   @default(PUBLISHED)
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  description String?
  /// Arbitrary type-specific payload (e.g. { amountPerShareCents } for a
  /// DIVIDEND row, { fromCents, toCents } for an EARNINGS estimate) — kept
  /// schemaless since the shape genuinely differs per RadarType and none of
  /// it is queried on yet.
  metadata    Json?
  occurredAt  DateTime
  createdAt   DateTime      @default(now())

  @@index([type, occurredAt])
  @@index([companyId, occurredAt])
  @@map("radar_events")
}

/// Prepared infrastructure for future push/in-app notifications — no send
/// mechanism exists yet (no email/push integration), see point 14 of the
/// Radar spec ("ainda sem envio, somente arquitetura"). A future delivery
/// job would create rows here per (profile, event) and a real send
/// pipeline would flip status PENDING -> PUBLISHED once delivered.
model RadarNotification {
  id        String        @id @default(uuid())
  profileId String
  profile   Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      RadarType
  priority  RadarPriority @default(MEDIUM)
  status    RadarStatus   @default(PENDING)
  title     String
  body      String?
  companyId String?
  company   Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([profileId, status, createdAt])
  @@map("radar_notifications")
}

// ─────────────────────────────────────────────────────────
// Market discovery
// ─────────────────────────────────────────────────────────

/// A user's named filter/sort combination on /mercado ("Meus filtros") —
/// applied client-side by rehydrating `filters` into the same shape
/// src/features/market/discovery-types.ts's MarketFilters/MarketSortOption
/// already use, never re-interpreted server-side. Kept schemaless (Json)
/// since the filter shape is still evolving; nothing else joins against it.
model SavedMarketFilter {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  filters   Json
  sort      String?
  createdAt DateTime @default(now())

  @@unique([profileId, name])
  @@map("saved_market_filters")
}
